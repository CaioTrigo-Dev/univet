{
  "expo": {
    "name": "UniVet",
    "slug": "univet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "univet",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.univet.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.univet.app"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Precisamos da sua localização para encontrar a unidade UniVet mais próxima."
        }
      ]
    ]
  }
}
